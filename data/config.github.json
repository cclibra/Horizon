  {
    "version": "1.0",
    "ai": {
      "provider": "openai",
      "model": "deepseek-v4-flash",
      "api_key_env": "OPENAI_API_KEY",
      "temperature": 0.3,
      "max_tokens": 4096,
      "throttle_sec": 1,
      "analysis_concurrency": 2,
      "enrichment_concurrency": 1,
      "languages": ["en", "zh"]
    },
    "sources": {
      "hackernews": {
        "enabled": true,
        "fetch_top_stories": 40,
        "min_score": 80
      },
      "rss": [
        {
          "name": "OpenAI News",
          "url": "https://openai.com/news/rss.xml",
          "enabled": true,
          "category": "ai-lab"
        },
        {
          "name": "Google AI Blog",
          "url": "https://blog.google/technology/ai/rss/",
          "enabled": true,
          "category": "ai-lab"
        },
        {
          "name": "Google Research",
          "url": "https://research.google/blog/rss/",
          "enabled": true,
          "category": "ai-research"
        },
        {
          "name": "Hugging Face Blog",
          "url": "https://huggingface.co/blog/feed.xml",
          "enabled": true,
          "category": "ai-devtools"
        },
        {
          "name": "LangChain Blog",
          "url": "https://blog.langchain.com/rss/",
          "enabled": true,
          "category": "ai-agent"
        },
        {
          "name": "LlamaIndex Blog",
          "url": "https://www.llamaindex.ai/blog/rss.xml",
          "enabled": true,
          "category": "ai-agent"
        },
        {
          "name": "Simon Willison",
          "url": "https://simonwillison.net/atom/everything/",
          "enabled": true,
          "category": "ai-engineering"
        },
        {
          "name": "The GitHub Blog",
          "url": "https://github.blog/feed/",
          "enabled": true,
          "category": "developer-tools"
        },
        {
          "name": "Cloudflare Blog",
          "url": "https://blog.cloudflare.com/rss/",
          "enabled": true,
          "category": "infra-security"
        },
        {
          "name": "InfoQ AI ML Data Engineering",
          "url": "https://feed.infoq.com/ai-ml-data-eng/",
          "enabled": true,
          "category": "tech-news"
        },
        {
          "name": "MIT Technology Review AI",
          "url": "https://www.technologyreview.com/feed/",
          "enabled": true,
          "category": "tech-news"
        }
      ],
      "reddit": {
        "enabled": true,
        "fetch_comments": 5,
        "subreddits": [
          {
            "subreddit": "LocalLLaMA",
            "enabled": true,
            "sort": "hot",
            "time_filter": "day",
            "fetch_limit": 20,
            "min_score": 50
          },
          {
            "subreddit": "MachineLearning",
            "enabled": true,
            "sort": "hot",
            "time_filter": "day",
            "fetch_limit": 20,
            "min_score": 50
          },
          {
            "subreddit": "singularity",
            "enabled": true,
            "sort": "hot",
            "time_filter": "day",
            "fetch_limit": 15,
            "min_score": 80
          },
          {
            "subreddit": "OpenAI",
            "enabled": true,
            "sort": "hot",
            "time_filter": "day",
            "fetch_limit": 15,
            "min_score": 50
          }
        ],
        "users": []
      },
      "github": [
        {
          "type": "repo_releases",
          "owner": "openai",
          "repo": "openai-python",
          "enabled": true
        },
        {
          "type": "repo_releases",
          "owner": "anthropics",
          "repo": "anthropic-sdk-python",
          "enabled": true
        },
        {
          "type": "repo_releases",
          "owner": "langchain-ai",
          "repo": "langchain",
          "enabled": true
        },
        {
          "type": "repo_releases",
          "owner": "run-llama",
          "repo": "llama_index",
          "enabled": true
        },
        {
          "type": "repo_releases",
          "owner": "microsoft",
          "repo": "autogen",
          "enabled": true
        },
        {
          "type": "repo_releases",
          "owner": "browser-use",
          "repo": "browser-use",
          "enabled": true
        },
        {
          "type": "repo_releases",
          "owner": "modelcontextprotocol",
          "repo": "servers",
          "enabled": true
        }
      ],
      "ossinsight": {
        "enabled": true,
        "period": "past_24_hours",
        "languages": ["All", "Python", "TypeScript", "Rust"],
        "keywords": [
          "agent",
          "agents",
          "llm",
          "mcp",
          "rag",
          "workflow",
          "automation",
          "browser",
          "coding"
        ],
        "min_stars": 20,
        "max_items": 40
      },
      "twitter": {
        "enabled": false,
        "users": ["karpathy", "sama", "ylecun", "OpenAI", "AnthropicAI"],
        "fetch_limit": 20,
        "fetch_reply_text": false,
        "max_replies_per_tweet": 3,
        "max_tweets_to_expand": 10,
        "reply_min_likes": 10
      },
      "telegram": {
        "enabled": false,
        "channels": []
      },
      "openbb": {
        "enabled": false,
        "fetch_filings": false,
        "watchlists": [
          {
            "name": "ai-megacaps",
            "enabled": true,
            "provider": "yfinance",
            "fetch_limit": 20,
            "category": "ai-equities",
            "symbols": ["NVDA", "MSFT", "GOOGL", "META", "AMZN", "TSLA", "AMD", "AVGO"]
          }
        ]
      }
    },
    "filtering": {
      "ai_score_threshold": 5.0,
      "time_window_hours": 72
    },
  "email": {
    "enabled": false,
    "smtp_server": "smtp.qq.com",
    "smtp_port": 465,
    "imap_server": "imap.qq.com",
    "imap_port": 993,
    "email_address": "xxx@qq.com",
    "sender_name": "Horizon Daily",
    "subscribe_keyword": "SUBSCRIBE",
    "unsubscribe_keyword": "UNSUBSCRIBE"
  },
    "webhook": {
      "enabled": false,
      "url_env": "HORIZON_WEBHOOK_URL",
      "delivery": "summary",
      "overview_position": "first",
      "platform": "generic",
      "layout": "markdown",
      "fallback_layout": "markdown",
      "languages": null,
      "request_body": {
        "text": "#{message_title}\n\n#{summary}"
      },
      "headers": ""
    }
  }
